      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        -3216,
        208
      ],
      "id": "cfe36032-b0ad-4a67-b9dd-bef7997189f5",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "F0660oiHuE8wv0Cv",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 1. Lấy kết quả văn bản từ Llama 3\nlet rawText = $input.item.json.text;\n\n// 2. BỘ LỌC CHỐNG ĐẠN (TÌM VÀ CẮT ĐÚNG PHẦN JSON)\n// Dù AI có nói nhảm gì trước hay sau, nó chỉ lấy phần nằm giữa { và }\nlet jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\nif (jsonMatch) {\n    rawText = jsonMatch[0];\n}\n\n// 3. Dịch sang object an toàn\nlet aiData = {};\ntry {\n    aiData = JSON.parse(rawText);\n} catch (e) {\n    // Kịch bản dự phòng: Rủi AI xuất tào lao thì tự gán mặc định để KHÔNG BAO GIỜ SẬP\n    aiData = {\n        tinh_chat_hang: \"FRAGILE\",\n        phi_de_vo: 5000,\n        thoi_tiet: \"Chưa xác định\",\n        phi_thoi_tiet: 0\n    };\n}\n\n// 4. Lấy Quãng đường từ Webhook\nlet quangDuong = $('Webhook').item.json.body.distance || 0;\nlet phiShipGoc = quangDuong * 5000;\n\n// 5. Gom phụ phí\nlet phiDeVo = parseInt(aiData.phi_de_vo) || 0;\nlet phiThoiTiet = parseInt(aiData.phi_thoi_tiet) || 0;\n\nlet tongTien = phiShipGoc + phiDeVo + phiThoiTiet;\n\n// 6. Trả về cho Laravel hiển thị Hóa đơn\nreturn {\n    \"tinh_chat_hang\": aiData.tinh_chat_hang,\n    \"phi_de_vo\": phiDeVo,\n    \"thoi_tiet\": aiData.thoi_tiet,\n    \"phi_thoi_tiet\": phiThoiTiet,\n    \"quang_duong\": quangDuong,\n    \"tong_tien\": tongTien\n};"
      },
