        336,
        0
      ],
      "id": "4af1c4e4-6e1d-4eaf-b866-397180f63b0f",
      "name": "Message a model",
      "credentials": {
        "googlePalmApi": {
          "id": "pB239Xitu96EDBUs",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 1. Lấy đoạn text mà AI vừa nhả ra\nlet rawText = $input.first().json.content.parts[0].text;\n\n// 2. Lọc bỏ mấy cái rác markdown\nrawText = rawText.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// 3. Dịch đoạn text đó sang chuẩn JSON\nlet aiData = JSON.parse(rawText);\n\n// --- PHẦN THÊM MỚI ---\n// Lấy phí ship gốc (21k) từ cái Node SQL đầu tiên (nơi nó vừa đọc DB lên)\nlet phi_ship_goc = $('Execute a SQL query').first().json.shipping_fee || 0;\n\n// Tính tổng các loại phụ phí do AI bắt mạch (50k)\nlet tong_phu_phi = (aiData.weather_surcharge || 0) + (aiData.risk_surcharge || 0);\n\n// Tính TỔNG CHI PHÍ CUỐI CÙNG = Gốc + Phụ phí (21k + 50k = 71k)\nlet tong_chi_phi = phi_ship_goc + tong_phu_phi;\n\n// 4. Trả ra kết quả sạch bong kin kít\nreturn {\n    tag_phan_loai: aiData.tag,\n    phi_thoi_tiet: aiData.weather_surcharge || 0,\n    phi_rui_ro: aiData.risk_surcharge || 0,\n    tong_phu_phi: tong_phu_phi,\n    tong_chi_phi: tong_chi_phi  // <--- CÁI MÀ WEB ĐANG CẦN ĐÂY\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        0
      ],
