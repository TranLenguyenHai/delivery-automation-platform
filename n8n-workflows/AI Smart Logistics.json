        "messages": {
          "values": [
            {
              "content": "=Bạn là hệ thống AI Điều phối Logistics.\nTôi có 1 đơn hàng với thông tin:\n- Ghi chú: \"{{ $('Execute a SQL query').item.json.note }}\"\n- Thời tiết: \"{{ $('HTTP Request').item.json.weather[0].description }}\"\n\nHãy trả về ĐÚNG 1 đoạn JSON (không giải thích) gồm 3 biến:\n1. \"tag\": Điền \"FRAGILE\" (nếu ghi chú nhắc đồ dễ vỡ/thủy tinh), \"URGENT\" (nếu giục gấp), \"NORMAL\" (nếu bình thường).\n2. \"weather_surcharge\": Điền 15000 nếu thời tiết có chữ \"mưa\" hoặc \"bão\". Nếu không điền 0.\n3. \"risk_surcharge\": Điền 50000 nếu tag là FRAGILE. Điền 20000 nếu tag là URGENT. Còn lại điền 0."
            }
          ]
        },
        "jsonOutput": true,
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
